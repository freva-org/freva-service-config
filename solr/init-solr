#!/usr/bin/env bash
set -o nounset -o pipefail -o errexit
[ "${DEBUG:-}" = "true" ] && set -x
export SERVICE=solr

temp_dir=$(mktemp -d)
export SOLR_SECURITY_MANAGER_ENABLED=false
export SOLR_OPTS="${SOLR_OPTS:-}"
SOLR_OPTS="${SOLR_OPTS//-Djava.security.manager/}"
SOLR_OPTS="$(echo "$SOLR_OPTS" | sed -E 's/-Djava\.security\.policy=[^ ]*//g')"
export SOLR_OPTS
export SOLR_PORT=${API_SOLR_PORT:-8983}
export SOLR_HEAP=${API_SOLR_HEAP:-4g}
export SOLR_CORE=${API_SOLR_CORE:-files}
export SOLR_LOGS_DIR=$LOG_DIR
export SOLR_HOST_BIND="0.0.0.0"
export SOLR_PID_DIR=/tmp/$SERVICE

mkdir -p "$SOLR_PID_DIR"

cleanup(){
  rm -fr "$SOLR_PID_DIR" || true
  rm -rf "$temp_dir" || true
  solr stop -p "$SOLR_PORT" || true
}
trap cleanup EXIT

is_solr_running(){
  curl -fsS "http://localhost:$1/solr/admin/info/system" >/dev/null 2>&1
}

core_instance_dir_by_name() {
  # Args: <core_name>
  local want="$1" f name
  shopt -s nullglob
  for f in "$DATA_DIR"/*/core.properties; do   # only files one level down
    name="$(sed -n 's/^[[:space:]]*name[[:space:]]*=[[:space:]]*//p' "$f" | head -n1)"
    name="${name%%[[:space:]]*}"               # trim trailing spaces
    if [[ "$name" == "$want" ]]; then
      dirname "$f"
      shopt -u nullglob
      return 0
    fi
  done
  shopt -u nullglob
  return 1
}

# robust copy: only copy files that exist
copy_conf_files() {
  # Copy the *entire* conf tree (xml, txt, json, synonyms, lang/, ...), not just
  # top-level *.xml/*.txt. cp does not delete, so a core's own configoverlay.json
  # survives. Fails loudly if the source conf is missing.
  local src="$1" dst="$2"
  [[ -d "$src" ]] || { echo "ERROR: config source dir not found: $src" >&2; return 1; }
  mkdir -p "$dst"
  cp -a "$src/." "$dst/"
}

configure_solr=false
declare -a WANTED_CORES
WANTED_CORES=( "$SOLR_CORE" "latest" )

# detect which cores are missing (by name, not path)
declare -a MISSING_CORES
declare -a EXISTING_CORES
for core in "${WANTED_CORES[@]}"; do
  if instdir="$(core_instance_dir_by_name "$core")"; then
    EXISTING_CORES+=( "$core:$instdir" )
  else
    MISSING_CORES+=( "$core" )
    configure_solr=true
  fi
done

# If we need to create any cores, start Solr once, create them, patch conf, then stop it.
if $configure_solr ; then
  if ! is_solr_running "$SOLR_PORT" ; then
    echo "Starting Solr on port $SOLR_PORT to create missing cores..."
    solr start \
      --force -m "$SOLR_HEAP" --solr-home "${DATA_DIR}" --user-managed \
      -p "$SOLR_PORT" -Dsolr.logs.dir="$temp_dir" -q --no-prompt \
      &> "$temp_dir/solr.log" &
    timeout 20 bash -c 'until curl -fsS "http://localhost:'"$SOLR_PORT"'/solr/admin/info/system" >/dev/null 2>&1; do sleep 2; done' || {
      echo "Error: Solr did not start within 20 seconds." >&2
      cat "$temp_dir/solr.log" >&2 || true
      exit 1
    }
  fi

  for core in "${MISSING_CORES[@]}"; do
    echo "Creating core '$core' ..."
    # Create with default config; we will overwrite conf files next.
    solr create -c "$core" --solr-url "http://localhost:$SOLR_PORT" || true
    # Resolve its real instanceDir after creation
    instdir="$(core_instance_dir_by_name "$core")"
    [[ -n "${instdir:-}" ]] || { echo "ERROR: could not locate instanceDir for newly created core '$core'." >&2; exit 1; }
    # Copy your base conf into the actual conf dir
    copy_conf_files "$CONFIG_DIR" "$instdir/conf"
    # Disable autoCreateFields (your existing behavior)
    # Best-effort: the freva solrconfig.xml already defaults this to false, so a
    # transient API hiccup here must not abort container start.
    curl -fsS "http://localhost:$SOLR_PORT/solr/$core/config" \
      -H 'Content-Type: application/json' \
      -d '{"set-user-property": {"update.autoCreateFields":"false"}}' >/dev/null \
      || echo "warn: could not set update.autoCreateFields on '$core' (defaulted via solrconfig.xml)" >&2
  done

  # Also rewrite conf for cores we already had (but at nonstandard dirs)
  for pair in "${EXISTING_CORES[@]}"; do
    core="${pair%%:*}"
    instdir="${pair#*:}"
    copy_conf_files "$CONFIG_DIR" "$instdir/conf"
  done

  # Stop the temp Solr (the final one starts foreground below)
  solr stop -p "$SOLR_PORT" || true
else
  # No creation needed, but keep conf in sync for existing cores
  for pair in "${EXISTING_CORES[@]}"; do
    core="${pair%%:*}"
    instdir="${pair#*:}"
    copy_conf_files "$CONFIG_DIR" "$instdir/conf"
  done
fi
# Seed the shared "freva" configset that blue/green rotation (solr index --rotate)
# creates new cores from. A standalone configset must live under conf/, and it
# must contain solrconfig.xml -- seeding it to the configset root (the previous
# behaviour) is why CREATE ... configSet=freva failed.
echo "Seeding configset 'freva' from ${CONFIG_DIR} ..."
copy_conf_files "$CONFIG_DIR" "${DATA_DIR}/configsets/freva/conf"
cp "$CONFIG_DIR/*.xml" "${DATA_DIR}/configsets/freva/conf/"


rm -rf "$temp_dir" || true

# - cleanup stale rotated cores -
shopt -s nullglob
for props in "$DATA_DIR"/*/core.properties; do
  name="$(sed -n 's/^[[:space:]]*name[[:space:]]*=[[:space:]]*//p' "$props" | head -n1)"
  name="${name%%[[:space:]]*}"
  case "$name" in
    files|latest) ;;                              # live cores
    files_*|latest_*)                             # rotation leftovers only
       echo "Removing stale rotated core: $(dirname "$props")"
       rm -rf "$(dirname "$props")" ;;
    *) ;;                                         # leave any other core untouched
  esac
done
shopt -u nullglob


# Final foreground Solr (managed by container/systemd)
exec solr start -f --force --solr-home "${DATA_DIR}" --user-managed -m "$SOLR_HEAP" -p "$SOLR_PORT"
